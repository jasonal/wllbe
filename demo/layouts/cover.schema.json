      "constraints": {
        "min_length": 0,
        "max_length": 60,
        "ideal_length": "10-30 字符",
        "line_count": 1
      },
      "examples": ["数据驱动 / 解耦架构 / 极致体验", "2026 年度技术路线图"]
    }
  },

  "lists": {},

  "ai_guidance": {
    "selection_hint": "当用户的内容只有一个核心短语或标题，且没有详细的解释性段落时，应选择此布局。",
    "content_adaptation": "将用户提供的核心信息浓缩为一句话标题（不超过 20 字符）。如果原始内容有补充说明，提炼为不超过 60 字符的副标题。",
    "tone": "简洁有力，避免长句"
  }
